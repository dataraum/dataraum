# DataRaum cockpit — TanStack Start production image.
#
# Multi-stage:
#   1. deps   — install pnpm deps (cached when package.json/lock unchanged)
#   2. build  — build the SSR bundle (uses the committed src/api/types.ts;
#               regenerate it with `pnpm codegen` before docker build if the
#               engine's openapi.yaml changed)
#   3. runner — minimal node image serving dist/server/server.js
#
# Build args:
#   VITE_ENGINE_API_URL — baked into the client bundle for cross-origin
#     fetches to the engine. Defaults to http://localhost:8000 for the
#     standard docker-compose host-port mapping.
#
# Runtime env:
#   PORT — server bind port (default 3000)
#
# Build via the workspace compose file:
#   docker compose -f packages/infra/docker-compose.yml build cockpit

# ---------- 1. deps ----------
FROM node:24-alpine AS deps
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
RUN pnpm install --frozen-lockfile

# ---------- 2. build ----------
FROM node:24-alpine AS build
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

ARG VITE_ENGINE_API_URL=http://localhost:8000
ENV VITE_ENGINE_API_URL=$VITE_ENGINE_API_URL

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# src/api/types.ts is the canonical client artifact. It's regenerated by
# `pnpm codegen` against ../api/openapi.yaml (outside this build context),
# committed alongside source. Docker build trusts the committed copy.
RUN pnpm build

# ---------- 3. runner ----------
FROM node:24-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production \
    PORT=3000 \
    HOSTNAME=0.0.0.0

# TanStack Start's prod server reads dist/ + node_modules at runtime.
COPY --from=build /app/dist ./dist
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./

EXPOSE 3000

HEALTHCHECK --interval=10s --timeout=5s --start-period=10s --retries=3 \
    CMD wget -qO- --spider http://localhost:3000/ || exit 1

CMD ["node", "dist/server/server.js"]
