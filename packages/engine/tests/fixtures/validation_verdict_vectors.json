{
  "_comment": "ADR-0017 shared verdict truth table (per-leg since DAT-852). The single source of truth for the validation judgement, asserted by BOTH the engine (pytest: tests/unit/analysis/validation/test_evaluate.py) and the cockpit (vitest, the TS mirror). The judgement is uniform: one row per independently-judged subject (multi-leg checks label rows with 'leg'); EVERY row is judged passed = deviation <= tolerance and the WORST row decides; a missing/non-numeric/non-finite deviation in ANY row (or no rows) is inconclusive (status 'error', never 'failed'); a garbage magnitude degrades to the deviation-then-1 fallback, never an error. expected.deviation/expected.magnitude, when present, pin the WORST-row numbers both mirrors must serve. Non-finite (NaN/Infinity) cases live in per-side unit tests because JSON cannot encode them. Keep the two consumers in lockstep — a divergence is a test failure, not a production surprise.",
  "cases": [
    {
      "name": "balance_clean_passes",
      "check_type": "balance",
      "tolerance": 0.01,
      "rows": [{ "deviation": 0.0, "magnitude": 150.0 }],
      "expected": { "status": "passed", "passed": true }
    },
    {
      "name": "balance_off_fails",
      "check_type": "balance",
      "tolerance": 0.01,
      "rows": [{ "deviation": 50.0, "magnitude": 150.0 }],
      "expected": { "status": "failed", "passed": false }
    },
    {
      "name": "deviation_exactly_at_tolerance_passes",
      "check_type": "comparison",
      "tolerance": 0.5,
      "rows": [{ "deviation": 0.5, "magnitude": 1000.0 }],
      "expected": { "status": "passed", "passed": true }
    },
    {
      "name": "aggregate_rate_over_tolerance_fails",
      "check_type": "aggregate",
      "tolerance": 0.01,
      "rows": [{ "deviation": 0.5, "magnitude": 1.0 }],
      "expected": { "status": "failed", "passed": false }
    },
    {
      "name": "constraint_zero_violations_passes",
      "check_type": "constraint",
      "tolerance": 0.01,
      "rows": [{ "deviation": 0.0, "magnitude": 1000.0 }],
      "expected": { "status": "passed", "passed": true }
    },
    {
      "name": "constraint_violations_fail",
      "check_type": "constraint",
      "tolerance": 0.01,
      "rows": [{ "deviation": 3.0, "magnitude": 1000.0 }],
      "expected": { "status": "failed", "passed": false }
    },
    {
      "name": "no_rows_is_inconclusive",
      "check_type": "balance",
      "tolerance": 0.01,
      "rows": [],
      "expected": { "status": "error", "passed": false }
    },
    {
      "name": "missing_deviation_column_is_inconclusive",
      "check_type": "comparison",
      "tolerance": 0.01,
      "rows": [{ "po_count": 5, "invoice_count": 3 }],
      "expected": { "status": "error", "passed": false }
    },
    {
      "name": "non_numeric_deviation_is_inconclusive",
      "check_type": "balance",
      "tolerance": 0.01,
      "rows": [{ "deviation": "not-a-number", "magnitude": 10.0 }],
      "expected": { "status": "error", "passed": false }
    },
    {
      "name": "negative_deviation_uses_absolute_value",
      "check_type": "comparison",
      "tolerance": 0.01,
      "rows": [{ "deviation": -42.0, "magnitude": 1000.0 }],
      "expected": { "status": "failed", "passed": false }
    },
    {
      "name": "absent_magnitude_still_judges_on_deviation",
      "check_type": "balance",
      "tolerance": 0.01,
      "rows": [{ "deviation": 0.0 }],
      "expected": { "status": "passed", "passed": true }
    },
    {
      "name": "multi_leg_all_within_tolerance_passes",
      "check_type": "aggregate",
      "tolerance": 0.02,
      "rows": [
        { "leg": "txns.account_id->accounts.id", "deviation": 0.0, "magnitude": 1.0 },
        { "leg": "txns.vendor_id->vendors.id", "deviation": 0.01, "magnitude": 1.0 }
      ],
      "expected": { "status": "passed", "passed": true, "deviation": 0.01, "magnitude": 1.0 }
    },
    {
      "name": "multi_leg_worst_leg_over_tolerance_fails",
      "check_type": "aggregate",
      "tolerance": 0.02,
      "rows": [
        { "leg": "txns.account_id->accounts.id", "deviation": 0.0, "magnitude": 1.0 },
        { "leg": "txns.vendor_id->vendors.id", "deviation": 0.315, "magnitude": 1.0 }
      ],
      "expected": { "status": "failed", "passed": false, "deviation": 0.315, "magnitude": 1.0 }
    },
    {
      "name": "multi_leg_unlabelled_rows_still_judged_per_row",
      "check_type": "aggregate",
      "tolerance": 0.01,
      "rows": [{ "deviation": 0.0 }, { "deviation": 3.0, "magnitude": 100.0 }],
      "expected": { "status": "failed", "passed": false, "deviation": 3.0, "magnitude": 100.0 }
    },
    {
      "name": "non_numeric_magnitude_degrades_to_fallback_not_error",
      "check_type": "aggregate",
      "tolerance": 10.0,
      "rows": [{ "deviation": 5.0, "magnitude": "garbage" }],
      "expected": { "status": "passed", "passed": true, "deviation": 5.0, "magnitude": 5.0 }
    },
    {
      "name": "multi_leg_missing_deviation_in_any_row_is_inconclusive",
      "check_type": "aggregate",
      "tolerance": 0.02,
      "rows": [
        { "leg": "txns.account_id->accounts.id", "deviation": 0.0, "magnitude": 1.0 },
        { "leg": "txns.vendor_id->vendors.id", "magnitude": 1.0 }
      ],
      "expected": { "status": "error", "passed": false }
    }
  ]
}
