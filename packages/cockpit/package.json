{
  "name": "dataraum-cockpit",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "trustedDependencies": ["esbuild"],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "preview": "bun --bun vite preview",
    "test": "vitest run",
    "format": "bun --bun biome format",
    "lint": "bun --bun biome lint",
    "check": "bun --bun biome check",
    "db:pull:metadata": "bunx drizzle-kit pull --config drizzle.config.metadata.ts && bun scripts/normalize-metadata-pull.mjs && bun --bun biome check --write --unsafe src/db/metadata/",
    "db:push:cockpit": "bunx drizzle-kit push --config drizzle.config.cockpit.ts",
    "db:generate:cockpit": "bunx drizzle-kit generate --config drizzle.config.cockpit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@mantine/core": "^9.2.1",
    "@mantine/hooks": "^9.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.168.11",
    "drizzle-orm": "1.0.0-rc.2-e38a2ba",
    "lucide-react": "^1.16.0",
    "nitro": "^3.0.260522-beta",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tanstack/devtools-vite": "latest",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "1.0.0-rc.2-e38a2ba",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}