{
  "name": "dataraum-cockpit",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "trustedDependencies": ["@swc/core", "esbuild", "protobufjs"],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "preview": "bun --bun vite preview",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "typecheck": "tsc --noEmit",
    "format": "bun --bun biome format",
    "lint": "bun --bun biome lint",
    "check": "bun --bun biome check",
    "db:pull:metadata": "bash scripts/pull-metadata.sh",
    "db:push:cockpit": "bun --bun drizzle-kit push --config drizzle.config.cockpit.ts",
    "db:generate:cockpit": "bun --bun drizzle-kit generate --config drizzle.config.cockpit.ts",
    "db:migrate:cockpit": "bun --bun drizzle-kit migrate --config drizzle.config.cockpit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-sql": "^6.10.0",
    "@dagrejs/dagre": "^3.0.0",
    "@duckdb/node-api": "^1.5.4-r.1",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/ai": "latest",
    "@tanstack/ai-anthropic": "latest",
    "@tanstack/ai-react": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/react-virtual": "latest",
    "@temporalio/activity": "^1.19.0",
    "@temporalio/client": "^1.19.0",
    "@temporalio/worker": "^1.19.0",
    "@temporalio/workflow": "^1.19.0",
    "@uwdata/mosaic-sql": "^0.28.1",
    "@xyflow/react": "^12.11.2",
    "dompurify": "^3.4.11",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.23.0",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "nitro": "^3.0.260522-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.4",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "1.0.0-rc.4-5d5b77c",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "5.0.0-beta.5"
  }
}