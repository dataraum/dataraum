# Cockpit environment template. The dev server runs OUTSIDE docker (hot
# reload) and talks to the compose Postgres on localhost:5432. Every var is
# validated once at boot by src/config.ts (server-only) — a missing/empty
# required var fails loud, naming the field. Keep this shape in sync with the
# engine's core/settings.py (no Python<->TS sync tool; the shared .env is it).

# --- Substrate (required) ---

# cockpit_db: the cockpit's own database in the shared Postgres instance
# (chat history, UI state). Owned by the cockpit via Drizzle.
COCKPIT_DATABASE_URL=postgres://dataraum:dataraum@localhost:5432/cockpit_db

# The engine's Postgres database. The cockpit reads engine metadata (the
# ws_<id> schema) read-only via the generated Drizzle metadata client.
METADATA_DATABASE_URL=postgres://dataraum:dataraum@localhost:5432/dataraum

# Active workspace id — MUST match the engine's DATARAUM_WORKSPACE_ID exactly
# (both key the ws_<id> schema off it). Non-UUID values are fine if both agree.
DATARAUM_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Read-only config tree (vertical ontologies) — the same path the engine resolves
# through DATARAUM_CONFIG_PATH. The cockpit reads it via fs (list_verticals scans
# verticals/* here). In-container this is /opt/dataraum/config; for `bun run dev`
# on the host it is the dataraum-config package dir relative to the cockpit.
DATARAUM_CONFIG_PATH=../dataraum-config

# DuckLake DATA_PATH — the s3:// URI the engine writes parquet to and the
# cockpit reads READ_ONLY. Must match the engine's DUCKLAKE_DATA_PATH exactly
# (DAT-388). The bucket path is the same from host or in-container.
DATARAUM_LAKE_PATH=s3://dataraum-lake/lake

# DuckLake catalog (Postgres) — the cockpit ATTACHes it READ_ONLY to read
# committed lake snapshots (run_sql, schema-sniff). Must point at the engine's
# DuckLake catalog DB. Required by src/config.ts (no default).
DUCKLAKE_CATALOG_URL=postgres://dataraum:dataraum@localhost:5432/dataraum_lake_catalog

# --- Object store (DAT-388; required) ---

# SeaweedFS S3 gateway the lake lives on. Creds flow through config.ts as plain
# env (single source = the shared .env), same posture as the URLs above; the S3
# endpoint is host:port, no scheme. The dev server runs OUTSIDE docker, so it
# reaches the gateway on the published host port (localhost:8333), not the
# compose service name. Dev gateway is anonymous — these creds are accepted but
# not verified locally.
S3_ENDPOINT=localhost:8333
S3_REGION=us-east-1
S3_USE_SSL=false
S3_ACCESS_KEY_ID=dataraum
S3_SECRET_ACCESS_KEY=dataraum-s3-secret

# Bucket uploads are staged into, under the uploads/ prefix (DAT-386). The SAME
# bucket the lake lives in — DATARAUM_LAKE_PATH above is s3://<S3_BUCKET>/lake,
# uploads land at s3://<S3_BUCKET>/uploads/<uuid>/<filename>. Must equal the
# engine/infra S3_BUCKET.
S3_BUCKET=dataraum-lake

# --- LLM (required) ---

# Anthropic API key — used by the chat server function. Required; fill in.
ANTHROPIC_API_KEY=

# --- Temporal (optional in slice-1; the cockpit Temporal client lands in
#     DAT-344, which flips host/namespace/task-queue to required) ---
# TEMPORAL_HOST=localhost:7233
# TEMPORAL_NAMESPACE=default
# TEMPORAL_TASK_QUEUE=dataraum-pipeline

# Temporal Web UI, linked by the /workflows section. Defaults to the
# docker-compose dev address (CORS already allows :3000).
# TEMPORAL_UI_URL=http://localhost:8080

# --- Observability (ADR-0019/DAT-705; optional) ---
# OTLP endpoint for traces — unset/empty = telemetry off. The composed stack's
# otel-lgtm collector publishes OTLP/HTTP on host :4318 (Grafana on :3001).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Sample database sources (optional; DAT-589) ---
# A configured DB source the agent/connect/probe can read. The NAME in the var is
# the source name: DATARAUM_<NAME>_URL → a source called <name> (lowercased), which
# list_sources surfaces and the probe source-picker offers.
#
# MUST be a `scheme://` URL — the backend is inferred from the SCHEME (mssql /
# sqlserver → mssql, postgres/postgresql, mysql/mariadb, sqlite). A bare keyword
# DSN (`Server=host,1433;Database=…`) ATTACHes fine but has no scheme, so the
# source can't be classified and won't appear in the picker (DAT-576 smoke). The
# value is passed verbatim into DuckDB's ATTACH; the self-signed dev cert needs
# `?TrustServerCertificate=true`. Host dev uses @localhost:1433; an in-container
# cockpit uses @mssql:1433. Bring the DB up first:
#   docker compose -f packages/infra/docker-compose.yml \
#                  -f packages/infra/docker-compose.sources.yml --profile mssql up -d --wait
# Leave commented unless the sample DB is running (an unreachable source only fails
# when actually probed, but there's no point advertising it otherwise).
# DATARAUM_WWI_URL=mssql://sa:Dataraum!Dev1@localhost:1433/WideWorldImporters?TrustServerCertificate=true
