{
	"name": "dataraum-cockpit",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"trustedDependencies": [
		"@swc/core",
		"esbuild",
		"protobufjs"
	],
	"engines": {
		"bun": ">=1.3.14"
	},
	"scripts": {
		"dev": "bun --bun vite dev --port 3000",
		"build": "bun --bun vite build",
		"start": "bun run .output/server/index.mjs",
		"preview": "bun --bun vite preview",
		"test": "vitest run --project unit",
		"test:integration": "vitest run --project integration",
		"typecheck": "tsc --noEmit",
		"format": "bun --bun biome format",
		"lint": "bun --bun biome lint",
		"check": "bun --bun biome check",
		"db:pull:metadata": "bash scripts/pull-metadata.sh",
		"workspace:create": "bun scripts/provision-workspace.ts create",
		"workspace:archive": "bun scripts/provision-workspace.ts archive",
		"db:push:cockpit": "bun --bun drizzle-kit push --config drizzle.config.cockpit.ts",
		"db:generate:cockpit": "bun --bun drizzle-kit generate --config drizzle.config.cockpit.ts",
		"db:migrate:cockpit": "bun --bun drizzle-kit migrate --config drizzle.config.cockpit.ts"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.4",
		"@codemirror/lang-sql": "^6.10.0",
		"@dagrejs/dagre": "^3.0.0",
		"@duckdb/node-api": "^1.5.4-r.1",
		"@mantine/core": "^9.4.1",
		"@mantine/hooks": "^9.4.1",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
		"@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
		"@opentelemetry/sdk-metrics": "^2.9.0",
		"@opentelemetry/sdk-trace-node": "^2.9.0",
		"@tailwindcss/vite": "^4.3.2",
		"@tanstack/ai": "latest",
		"@tanstack/ai-anthropic": "latest",
		"@tanstack/ai-react": "latest",
		"@tanstack/react-query": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/react-table": "latest",
		"@tanstack/react-virtual": "latest",
		"@temporalio/activity": "^1.20.1",
		"@temporalio/client": "^1.20.1",
		"@temporalio/interceptors-opentelemetry-v2": "^1.20.1",
		"@temporalio/worker": "^1.20.1",
		"@uwdata/mosaic-sql": "^0.28.1",
		"@xyflow/react": "^12.11.2",
		"better-auth": "1.7.0-rc.1",
		"dompurify": "^3.4.11",
		"drizzle-orm": "1.0.0-rc.4-5d5b77c",
		"highlight.js": "^11.11.1",
		"lucide-react": "^1.23.0",
		"marked": "^18.0.5",
		"marked-highlight": "^2.2.4",
		"nitro": "^3.0.260522-beta",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"sql-formatter": "^15.8.2",
		"tailwindcss": "^4.3.2",
		"vega": "^6.2.0",
		"vega-lite": "^6.4.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@tanstack/devtools-vite": "latest",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.4",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"bun-types": "^1.3.14",
		"drizzle-kit": "1.0.0-rc.4-5d5b77c",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "5.0.0-beta.5"
	},
	"overrides": {
		"kysely": "0.28.17"
	}
}
