{
  "name": "dataraum-cockpit",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "trustedDependencies": ["esbuild", "protobufjs"],
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun --bun vite dev --port 3000",
    "build": "bun --bun vite build",
    "start": "bun run .output/server/index.mjs",
    "preview": "bun --bun vite preview",
    "test": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "format": "bun --bun biome format",
    "lint": "bun --bun biome lint",
    "check": "bun --bun biome check",
    "db:pull:metadata": "bash scripts/pull-metadata.sh",
    "db:push:cockpit": "bun --bun drizzle-kit push --config drizzle.config.cockpit.ts",
    "db:generate:cockpit": "bun --bun drizzle-kit generate --config drizzle.config.cockpit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@duckdb/node-api": "^1.5.3-r.3",
    "@mantine/core": "^9.3.0",
    "@mantine/hooks": "^9.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/ai": "latest",
    "@tanstack/ai-anthropic": "latest",
    "@tanstack/ai-react": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/react-virtual": "latest",
    "@tanstack/router-plugin": "latest",
    "@temporalio/client": "^1.17.2",
    "dompurify": "^3.4.8",
    "drizzle-orm": "1.0.0-rc.4-5d5b77c",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.4",
    "marked-highlight": "^2.2.4",
    "nitro": "^3.0.260522-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tanstack/ai-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "bun-types": "^1.3.14",
    "drizzle-kit": "1.0.0-rc.4-5d5b77c",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}