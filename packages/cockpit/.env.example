# Postgres connection string for cockpit_db (chat history, UI state).
# cockpit_db is its own database inside the shared Postgres instance.
COCKPIT_DATABASE_URL=postgres://dataraum:dataraum@localhost:5432/cockpit_db

# Base URL for the Python engine REST API. Browser fetches this directly
# for non-chat data; TanStack Start server functions use it from the tool
# registry.
ENGINE_API_URL=http://localhost:8000

# Anthropic API key — used by the chat BFF (step 6).
# ANTHROPIC_API_KEY=
