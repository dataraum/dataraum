# Copy to .env on first compose-up: `cp .env.example .env`
# All values here are dev defaults; override for any non-local environment.

# Postgres (platform + DuckLake catalog + cockpit_db)
POSTGRES_USER=dataraum
POSTGRES_PASSWORD=dataraum
POSTGRES_DB=dataraum
DUCKLAKE_CATALOG_DB=dataraum_lake_catalog
COCKPIT_DB=cockpit_db

# Active workspace_id (DAT-339 pivot, schema-per-workspace).
# Engine resolves the Postgres schema name as ws_<id-with-dashes-as-underscores>
# (e.g. ws_00000000_0000_0000_0000_000000000001). Cockpit dev uses the same
# value for drizzle-kit pull + the metadata client.
# Defaulted in docker-compose.yml; override here to use a different workspace.
#
# DAT-505: a workspace = one engine container + one task queue + one catalog DB
# + one s3://<ws>/ prefix. The engine-worker container DERIVES, per workspace:
#   - TEMPORAL_TASK_QUEUE = engine-<DATARAUM_WORKSPACE_ID>  (asserted at boot)
#   - DUCKLAKE_DATA_PATH  = s3://${S3_BUCKET}/<DATARAUM_WORKSPACE_ID>/lake
#   - DUCKLAKE_CATALOG_URL → ${DUCKLAKE_CATALOG_DB} (workspace 1) / _2 (workspace 2)
# The cockpit drivers route workflows to engine-<id> read from the cockpit_db
# registry row — NOT a shared TEMPORAL_TASK_QUEUE (that var is gone for routing).
DATARAUM_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Second workspace for the AC1 two-workspace side-by-side smoke (DAT-505). Only
# used by the `multi-workspace` compose profile's engine-worker-2:
#   docker compose --profile multi-workspace up -d
# Its queue (engine-<id>), ws_<id> schema, catalog DB (${DUCKLAKE_CATALOG_DB}_2),
# and s3://<ws2>/lake prefix are all isolated from workspace 1.
DATARAUM_WORKSPACE_ID_2=00000000-0000-0000-0000-000000000002

# File sources are addressed by an s3:// URI on the object store (DAT-389) — no
# sources bind-mount. Upload files into the bucket (s3://${S3_BUCKET}/...) and
# register the source with its s3:// URI; the engine reads it over httpfs.

# Host directory bind-mounted read-only at /opt/dataraum/config in both the
# engine and cockpit containers (DAT-361). Defaults to the sibling
# dataraum-config package; point elsewhere to use a different config tree.
HOST_CONFIG_DIR=../dataraum-config

# LLM provider. Consumed by BOTH the engine (Pydantic Settings) and the
# cockpit (Zod config) as of DAT-363. Required + non-empty: the cockpit's Zod
# schema rejects an empty value at boot. This dev default is a non-functional
# placeholder so the stack boots (and compose-smoke passes) — replace it with a
# real key to actually use chat / LLM phases.
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me

# Temporal server stack (DAT-344). Pinned image versions for the
# temporalio/server + admin-tools + ui services, adapted from
# temporalio/samples-server compose/docker-compose-postgres.yml (the canonical
# non-deprecated path; temporalio/auto-setup is retired). The Temporal DBs
# (temporal + temporal_visibility) are created in the shared `postgres` service.
# Pinned to floating MAJOR tags so rebuilds pick up patch/minor fixes within the
# major without manual bumps. The UI image publishes no bare-major (`2`) or
# minor-float (`2.51`) tag — only `latest` (unbounded, could cross a major) or
# fully-pinned patches — so it carries an explicit patch pin, bumped manually.
TEMPORAL_VERSION=1
TEMPORAL_ADMINTOOLS_VERSION=1
TEMPORAL_UI_VERSION=2.51.1

# Temporal client settings. Read by the engine activity worker (DAT-344 P2) and
# the cockpit Temporal client (E4b). In-container values: the worker reaches the
# server at `temporal:7233` (compose service name).
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=default
# NOTE (DAT-505): the TASK QUEUE is now PER WORKSPACE (engine-<workspace_id>),
# derived in docker-compose.yml from DATARAUM_WORKSPACE_ID — it is NOT taken from
# a shared TEMPORAL_TASK_QUEUE env anymore. The engine still validates it (Pydantic
# Settings), and the per-workspace compose service supplies the engine-<id> value;
# the cockpit drivers route to engine-<id> from the cockpit_db registry row. This
# bare var is left here only as a non-routing default for ad-hoc single-process
# worker runs (`uv run python -m dataraum.worker.main`) of workspace 1.
TEMPORAL_TASK_QUEUE=engine-00000000-0000-0000-0000-000000000001

# Object store — SeaweedFS S3 gateway (DAT-388 lake-on-S3). The engine writes
# DuckLake parquet here and the cockpit reads it; both resolve the lake to
# s3://${S3_BUCKET}/lake. The in-container endpoint is the compose service name
# (host:port, no scheme — DuckDB's S3 ENDPOINT form). These are LOCAL-ONLY dev
# defaults (committed, like POSTGRES_PASSWORD): the dev gateway runs anonymous,
# so the creds are accepted but not verified locally — replace with real creds
# (and a real endpoint + S3_USE_SSL=true) for any non-local environment.
# SeaweedFS image is intentionally unpinned (:latest) for this dev-only,
# ephemeral store — no SEAWEEDFS_VERSION to bump.
S3_ENDPOINT=seaweedfs:8333
S3_BUCKET=dataraum-lake
S3_REGION=us-east-1
S3_USE_SSL=false
S3_ACCESS_KEY_ID=dataraum
S3_SECRET_ACCESS_KEY=dataraum-s3-secret

# ── Sample source backends (DAT-589) — OPT-IN via docker-compose.sources.yml ──
# Only read by the `mssql` profile in docker-compose.sources.yml; the core stack
# never touches these. SA password for the dev SQL Server (SQL Server enforces
# 8+ chars with upper/lower/digit/symbol). Local-dev default, committed like
# POSTGRES_PASSWORD — override for anything non-local.
MSSQL_SA_PASSWORD=Dataraum!Dev1
